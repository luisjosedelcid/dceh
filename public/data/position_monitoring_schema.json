{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DCE Position Monitoring (IPS §4.7)",
  "description": "Schema para los umbrales Tier 1 de cada posición. Validar todos los archivos monitoring_{ticker}.json contra este schema antes de aceptarlos en el Investment Memo.",
  "type": "object",
  "required": ["ticker", "company", "classification", "tesis_resumen", "tier_1_metrics", "_meta"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["established_at", "established_in_memo", "approved_by", "ips_reference"],
      "properties": {
        "established_at": {
          "type": "string",
          "format": "date",
          "description": "Fecha en que se establecieron los umbrales (debe coincidir con aprobación del Investment Memo)"
        },
        "established_in_memo": {
          "type": "string",
          "description": "Filename del Investment Memo en que se aprobaron los umbrales"
        },
        "approved_by": {
          "type": "string",
          "description": "CIO que aprobó (firma)"
        },
        "ips_reference": {
          "type": "string",
          "default": "IPS §4.7"
        },
        "last_modified": {
          "type": "string",
          "format": "date"
        },
        "modification_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "metric_id", "old_yellow", "old_red", "new_yellow", "new_red", "structural_change_rationale", "approved_by"],
            "properties": {
              "date": { "type": "string", "format": "date" },
              "metric_id": { "type": "string" },
              "old_yellow": { "type": "number" },
              "old_red": { "type": "number" },
              "new_yellow": { "type": "number" },
              "new_red": { "type": "number" },
              "structural_change_rationale": {
                "type": "string",
                "minLength": 50,
                "description": "Justificación obligatoria — cambio estructural del negocio o sector (NO la métrica acercándose al umbral)"
              },
              "approved_by": { "type": "string" }
            }
          }
        }
      }
    },
    "ticker": { "type": "string", "pattern": "^[A-Z]{1,5}$" },
    "company": { "type": "string" },
    "classification": {
      "type": "string",
      "enum": ["Core Compounder", "Opportunistic Compounder", "Value & Special Situation"]
    },
    "tesis_resumen": {
      "type": "string",
      "minLength": 30,
      "description": "Resumen ejecutivo de la tesis que las métricas Tier 1 buscan validar/desconfirmar"
    },
    "tier_1_metrics": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "description": "4-5 métricas Tier 1, debe incluir SIEMPRE ROIC_MARGINAL",
      "contains": {
        "type": "object",
        "properties": {
          "id": { "const": "ROIC_MARGINAL" }
        }
      },
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "direction", "unit", "yellow_threshold", "red_threshold", "data_source", "thesis_link"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z_0-9]+$",
            "description": "Identificador estable. Ejemplos: ROIC_MARGINAL, AZURE_GROWTH, GROSS_MARGIN, DSO_DAYS"
          },
          "name": { "type": "string" },
          "description": { "type": "string", "minLength": 20 },
          "direction": {
            "type": "string",
            "enum": ["higher_is_better", "lower_is_better", "range"],
            "description": "Cómo interpretar la métrica relativa a los umbrales"
          },
          "unit": {
            "type": "string",
            "description": "Ej: '%', 'bps', 'days', 'USD_M', 'ratio'"
          },
          "expected_range": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2,
            "description": "[min, max] del rango esperado bajo tesis (semáforo verde)"
          },
          "yellow_threshold": {
            "type": "number",
            "description": "Umbral de alerta. Valor numérico exacto."
          },
          "red_threshold": {
            "type": "number",
            "description": "Umbral de acción. Valor numérico exacto."
          },
          "data_source": {
            "type": "string",
            "description": "Fuente de la métrica: '10-K Item 7', 'FMP API', 'Bloomberg', etc."
          },
          "frequency": {
            "type": "string",
            "enum": ["quarterly", "semiannual", "annual"],
            "default": "quarterly"
          },
          "thesis_link": {
            "type": "string",
            "minLength": 20,
            "description": "Cómo esta métrica valida o desconfirma la tesis"
          },
          "current_value": {
            "type": ["number", "null"],
            "description": "Último valor observado (actualizado por el Scorecard trimestral)"
          },
          "current_status": {
            "type": ["string", "null"],
            "enum": ["GREEN", "YELLOW", "RED", null]
          },
          "last_updated": {
            "type": ["string", "null"],
            "format": "date"
          }
        }
      }
    }
  }
}
