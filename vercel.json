    { "source": "/sap", "destination": "/company.html?ticker=SAP" },
    { "source": "/universe", "destination": "/universe.html" },
    { "source": "/screener", "destination": "/screener.html" },
    { "source": "/portfolio", "destination": "/portfolio.html" },
    { "source": "/news", "destination": "/news.html" },
    { "source": "/dataroom", "destination": "/dataroom.html" },
    { "source": "/reporting", "destination": "/reporting.html" },
    { "source": "/research", "destination": "/research.html" },
    { "source": "/study", "destination": "/study.html" },
    { "source": "/journal", "destination": "/journal.html" },
    { "source": "/performance", "destination": "/performance.html" }
